# Supabase (same project as iOS OnPro app — see OnPro/SUPABASE_SETUP.md)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser bundle (required for team Google Calendar sync in Live)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mock-only deploy (GitHub / public Vercel): omit keys above, or set:
# NEXT_PUBLIC_USE_SUPABASE=false

# Production (Vercel): set Supabase keys above — app uses Live only (no mock toggle).
# Local dev: optional Live/Mock toggle in the sidebar when Supabase is configured.

# Partner development ledger (existing)
LEDGER_PASSWORD=jerryonpro

# Mailroom agent (server routes only — never NEXT_PUBLIC_)
OPENAI_API_KEY=sk-proj-your-key-here
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Gmail Mailroom (Live mode — server only)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional override (default: {origin}/api/mailroom/gmail/callback)
# GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/mailroom/gmail/callback
# Optional Gmail push (Pub/Sub) — incremental inbox sync; push URL: /api/mailroom/gmail/push
# GMAIL_PUBSUB_TOPIC=projects/your-gcp-project/topics/gmail-mailroom
